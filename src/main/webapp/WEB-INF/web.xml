<?xml version="1.0" encoding="UTF-8"?>
<web-app xmlns="http://xmlns.jcp.org/xml/ns/javaee"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://xmlns.jcp.org/xml/ns/javaee
         http://xmlns.jcp.org/xml/ns/javaee/web-app_4_0.xsd"
         version="4.0">

    <display-name>SQL Query Evaluator</display-name>
    <!-- AUTH FILTER -->
    <filter>
        <filter-name>AuthFilter</filter-name>
        <filter-class>com.sqlsystem.filter.AuthFilter</filter-class>
    </filter>
    <filter-mapping>
        <filter-name>AuthFilter</filter-name>
        <url-pattern>/*</url-pattern>
    </filter-mapping>

    <!-- LOGIN SERVLET -->
    <servlet>
        <servlet-name>LoginServlet</servlet-name>
        <servlet-class>com.sqlsystem.controller.LoginServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>LoginServlet</servlet-name>
        <url-pattern>/login</url-pattern>
    </servlet-mapping>

    <!-- LOGOUT SERVLET -->
    <servlet>
        <servlet-name>LogoutServlet</servlet-name>
        <servlet-class>com.sqlsystem.controller.LogoutServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>LogoutServlet</servlet-name>
        <url-pattern>/logout</url-pattern>
    </servlet-mapping>

    <!-- QUERY SERVLET -->
    <servlet>
        <servlet-name>QueryController</servlet-name>
        <servlet-class>com.sqlsystem.controller.QueryController</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>QueryController</servlet-name>
        <url-pattern>/query</url-pattern>
    </servlet-mapping>
    
    <!-- ADMIN QUERY SERVLET -->
	<servlet>
	    <servlet-name>AdminQueryServlet</servlet-name>
	    <servlet-class>com.sqlsystem.controller.AdminQueryServlet</servlet-class>
	</servlet>
	<servlet-mapping>
	    <servlet-name>AdminQueryServlet</servlet-name>
	    <url-pattern>/adminquery</url-pattern>
	</servlet-mapping>

    <!-- DEFAULT PAGE -->
    <welcome-file-list>
        <welcome-file>login.html</welcome-file>
    </welcome-file-list>

    <resource-ref>
        <res-ref-name>jdbc/SQLPracticeDB</res-ref-name>
        <res-type>javax.sql.DataSource</res-type>
        <res-auth>Container</res-auth>
    </resource-ref>

</web-app>